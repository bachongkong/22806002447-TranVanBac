JWT_REFRESH_EXPIRES_IN=7d

# Client
CLIENT_URL=http://localhost:3000

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SmartHire" <noreply@smarthire.com>
